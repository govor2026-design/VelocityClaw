# Velocity Claw environment configuration
ENV=production
LOG_LEVEL=INFO
SAFE_MODE=true
DEV_MODE=false
TRUSTED_MODE=false
MEMORY_ENABLED=true
MEMORY_DB_PATH=velocity_claw_memory.db
MEMORY_RETENTION_DAYS=30
MEMORY_RETENTION_MIN_RUNS=10
MEMORY_CLEANUP_VACUUM=true
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434
ALLOWED_USERS=
DEFAULT_MODEL=code
LIGHTWEIGHT_MODE=false
WORKSPACE_ROOT=.
ALLOWED_HOSTS=api.github.com,raw.githubusercontent.com
COMMAND_TIMEOUT=120
MAX_FILE_SIZE=10485760
MAX_HTTP_RESPONSE_BYTES=5242880
SHELL_ENABLED=false
GIT_ENABLED=false
DRY_RUN=false
EXECUTION_PROFILE=safe
PROVIDER_REQUEST_TIMEOUT_SECONDS=60
PROVIDER_MAX_RETRIES=2
PROVIDER_RETRY_BACKOFF_MS=250
PROVIDER_HEALTH_COOLDOWN_SECONDS=30
